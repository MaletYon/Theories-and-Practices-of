% Séparateur décoratif
\newcommand{\separateur}{%
    \begin{center}
        \color{CouleurAccent}
        \rule{0.4\linewidth}{0.4pt}\quad\ding{109}\quad\rule{0.4\linewidth}{0.4pt}
    \end{center}
    \vspace{0.5ex}
}

% Hash cryptographique (affichage formaté)
% Usage : \hash{SHA-256}{3a4b5c...}
\newcommand{\hash}[2]{%
    \texttt{\footnotesize\color{CouleurBordCode}[#1]~#2}%
}

% Balise Trilemme CRO inline
% Usage : \cro{C+}{R-}{O0} pour indiquer l'impact sur chaque dimension
\newcommand{\cro}[3]{%
    \mbox{%
        \textcolor{CouleurCRO}{$\mathcal{C}$:~#1}\;%
        \textcolor{CouleurBordLizbiz}{$\mathcal{R}$:~#2}\;%
        \textcolor{CouleurAccent}{$\mathcal{O}$:~#3}%
    }%
}

% Ordre de volatilité (inline)
% Usage : \volatilite{1}{RAM} pour "Priorité 1 — RAM"
\newcommand{\volatilite}[2]{%
    \colorbox{CouleurPrimaire}{\color{white}\footnotesize\bfseries~#1~}~\textit{#2}%
}

