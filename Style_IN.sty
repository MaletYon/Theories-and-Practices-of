% ==============================================================================
% IV. STYLES DE CHAPITRES ET SECTIONS
% ==============================================================================

\RequirePackage{titlesec}
\RequirePackage{titletoc}

% --- Style de chapitre ---
\titleformat{\chapter}[display]
    {\normalfont\bfseries\color{CouleurPrimaire}}
    {%
        \filleft
        \begin{tikzpicture}
            \fill[CouleurPrimaire] (0,0) rectangle (1.2,1.2);
            \node[white, font=\fontsize{28}{28}\selectfont\bfseries]
                at (0.6,0.6) {\thechapter};
        \end{tikzpicture}
    }
    {-0.5ex}
    {\filright\fontsize{18}{22}\selectfont\MakeUppercase}
    [\vspace{0.5ex}{\color{CouleurAccent}\titlerule[2pt]}\vspace{1ex}]

\titlespacing*{\chapter}{0pt}{10pt}{25pt}

% --- Style de section ---
\titleformat{\section}
    {\normalfont\large\bfseries\color{CouleurPrimaire}}
    {\colorbox{CouleurPrimaire}{\color{white}\,\thesection\,}}
    {0.7em}{}
    [\vspace{-0.4ex}{\color{CouleurSecondaire}\titlerule[0.8pt]}]

\titlespacing*{\section}{0pt}{1.4ex plus 0.5ex}{0.8ex plus 0.3ex}

% --- Style de sous-section ---
\titleformat{\subsection}
    {\normalfont\normalsize\bfseries\color{CouleurSecondaire}}
    {\thesubsection}{0.6em}{}

\titlespacing*{\subsection}{0pt}{1.2ex plus 0.4ex}{0.5ex plus 0.2ex}

% --- Style de sous-sous-section ---
\titleformat{\subsubsection}
    {\normalfont\normalsize\itshape\color{CouleurAccent}}
    {\thesubsubsection}{0.5em}{}

\titlespacing*{\subsubsection}{0pt}{0.8ex plus 0.3ex}{0.3ex plus 0.1ex}


% ==============================================================================
% V. EN-TÊTES ET PIEDS DE PAGE
% ==============================================================================

\pagestyle{fancy}
\fancyhf{}

\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.4pt}
\renewcommand{\headrule}{\color{CouleurPrimaire}\hrule width\headwidth height\headrulewidth}
\renewcommand{\footrule}{\color{CouleurAccent}\hrule width\headwidth height\footrulewidth}

\fancyhead[LE]{\small\color{CouleurPrimaire}\leftmark}
\fancyhead[RO]{\small\color{CouleurPrimaire}\rightmark}
\fancyhead[LO,RE]{\small\color{CouleurAccent}\textit{TPIN — UE\,GES4062}}

\fancyfoot[C]{\small\color{CouleurPrimaire}\thepage}
\fancyfoot[LE,RO]{\small\color{CouleurTexte}\textit{Théorie et Pratique de l'Investigation Numérique}}

\fancypagestyle{plain}{%
